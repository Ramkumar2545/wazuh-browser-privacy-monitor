<!--
  Wazuh Browser Privacy Monitor — Decoder
  Author  : Ram Kumar G (IT Fortress)
  Version : 1.2.0 (Phase 3 - Privacy-Safe Telemetry Edition)

  FIX v1.2.0:
    - Unified decoder naming: both JSON-direct and syslog-relay paths
      now produce decoder name "browser-privacy-monitor" so that
      rules using <decoded_as>browser-privacy-monitor</decoded_as>
      fire correctly regardless of how the log arrives.

    PATH A — log_format="json" (recommended for Wazuh agent direct):
      Wazuh parses JSON natively. The prematch decoder tags the event
      with name "browser-privacy-monitor". The child JSON_Decoder
      extracts all fields.

    PATH B — log_format="syslog" (syslog relay / forwarded logs):
      Syslog header is pre-decoded by Wazuh (Phase 1). The parent
      decoder matches program_name="browser-privacy-monitor" and is
      also named "browser-privacy-monitor" so rules see the same
      decoder name. The child JSON_Decoder extracts all fields from
      the syslog message body.

  Localfile config — PATH A (recommended):
    Linux/macOS:
      <localfile>
        <log_format>json</log_format>
        <location>/root/.browser-privacy-monitor/browser_privacy.log</location>
      </localfile>

    Windows:
      <localfile>
        <log_format>json</log_format>
        <location>C:\BrowserPrivacyMonitor\browser_privacy.log</location>
      </localfile>

  Localfile config — PATH B (syslog relay):
    <localfile>
      <log_format>syslog</log_format>
      <location>/var/log/browser-privacy-monitor.log</location>
    </localfile>

  JSON fields emitted by collector:
    integration, event_type, version, timestamp, endpoint, platform,
    user, browser, browser_profile, domain,
    sensitive_detected, sensitive_type, risk_category, risk_score,
    url_redacted, url_hash, title_redacted, title_hash
-->

<!-- ══════════════════════════════════════════════════════════════
     PATH A — log_format="json" (direct agent JSON ingestion)
     prematch fires on the raw JSON line and assigns decoder name
     "browser-privacy-monitor" so rules decoded_as matches.
     ══════════════════════════════════════════════════════════════ -->

<decoder name="browser-privacy-monitor">
  <prematch>{"integration": "browser-privacy-monitor"</prematch>
</decoder>

<decoder name="browser-privacy-monitor-fields">
  <parent>browser-privacy-monitor</parent>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>

<!-- ══════════════════════════════════════════════════════════════
     PATH B — log_format="syslog" (syslog relay / forwarded)
     The syslog header is pre-decoded by Wazuh (Phase 1) and
     program_name is extracted. This parent decoder ALSO uses name
     "browser-privacy-monitor" (same as PATH A) so that rules with
     <decoded_as>browser-privacy-monitor</decoded_as> fire for
     BOTH ingestion paths without any rule duplication.

     Syslog line format:
       Apr 18 10:00:00 WIN-01 browser-privacy-monitor: {"integration":...
     ══════════════════════════════════════════════════════════════ -->

<decoder name="browser-privacy-monitor">
  <program_name>^browser-privacy-monitor$</program_name>
</decoder>

<decoder name="browser-privacy-monitor-fields">
  <parent>browser-privacy-monitor</parent>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>

<!--
  Wazuh Browser Privacy Monitor — Decoder
  Author  : Ram Kumar G (IT Fortress)
  Version : 2.0.1 (Phase 3 - Privacy-Safe Telemetry Edition)

  ─────────────────────────────────────────────────────────────────────
  CRITICAL NOTE — Why the primary ingestion path needs NO custom decoder
  ─────────────────────────────────────────────────────────────────────
    Installers configure the Wazuh agent with:
        <localfile>
          <log_format>json</log_format>
          <location>.../browser_privacy.log</location>
        </localfile>

    When Wazuh ingests a JSON localfile, the native JSON decoder runs
    and tags the event with decoder.name="json". Custom decoders with
    <prematch> only execute in the text/syslog decoding pipeline and
    are NEVER applied to JSON localfiles. Therefore the rules file
    (0320-browser_privacy_rules.xml) uses:

        <decoded_as>json</decoded_as>
        <field name="integration">browser-privacy-monitor</field>

    which is the documented Wazuh pattern (same as VirusTotal).

    This decoder file is therefore only used for PATH B — syslog
    relay — where the collector's JSON is forwarded through rsyslog
    or syslog-ng and arrives at the manager with a syslog header.

  ─────────────────────────────────────────────────────────────────────
  FIX v2.0.1 — Wazuh Dashboard / API validation error
  ─────────────────────────────────────────────────────────────────────
    Previous v2.0.0 had two top-level <decoder> siblings. This works
    fine for wazuh-analysisd when dropping the file directly into
    /var/ossec/etc/decoders/, but the Wazuh Manager API endpoint
        PUT /decoders/files/<filename>
    validates uploads with a strict XML parser (libxml2). Strict XML
    requires exactly one root element, so the dashboard "Edit
    decoder" save returned an error that surfaced as:
        returnErrorInstance → apiReq  (in wazuh.plugin.js)

    Fix: wrap both <decoder> entries inside a single <decoders> root.
    Wazuh accepts this form for both direct file copy and API upload.

  ─────────────────────────────────────────────────────────────────────
  PATH B — log_format="syslog" (syslog relay / forwarded)

  Example syslog line:
    Apr 18 10:00:00 WIN-01 browser-privacy-monitor: {"integration":...

  The parent decoder matches program_name; the child plugin decoder
  parses the JSON body of the syslog message.

  Add the corresponding localfile on the forwarding host:
    <localfile>
      <log_format>syslog</log_format>
      <location>/var/log/browser-privacy-monitor.log</location>
    </localfile>
  ─────────────────────────────────────────────────────────────────────
-->

<decoders>

  <decoder name="browser-privacy-monitor-syslog">
    <program_name>^browser-privacy-monitor$</program_name>
  </decoder>

  <decoder name="browser-privacy-monitor-syslog-json">
    <parent>browser-privacy-monitor-syslog</parent>
    <plugin_decoder>JSON_Decoder</plugin_decoder>
  </decoder>

</decoders>
